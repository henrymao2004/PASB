{
  "_comment": "OpenClaw config (Skill Workshop 2026-06 schema). Proxy MUST forward tools/tool_choice (see examples/proxies/ and docs/TROUBLESHOOTING.md §1). Skill Workshop is built into the OpenClaw CLI; settings live at top-level skills.workshop.*.",
  "gateway": {
    "mode": "local",
    "port": ${PASB_OC_GATEWAY_PORT},
    "auth": {"mode": "token", "token": "pasb-pilot"}
  },
  "models": {
    "providers": {
      "custom-proxy": {
        "baseUrl": "${PASB_BACKBONE_URL}",
        "apiKey": "${PASB_BACKBONE_API_KEY}",
        "api": "openai-completions",
        "models": [{
          "id": "${PASB_BACKBONE_MODEL}",
          "name": "${PASB_BACKBONE_MODEL} (PASB)",
          "contextWindow": 65536,
          "maxTokens": 4096
        }]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {"primary": "custom-proxy/${PASB_BACKBONE_MODEL}"},
      "models": {"custom-proxy/${PASB_BACKBONE_MODEL}": {}}
    }
  },
  "tools": {
    "profile": "coding",
    "alsoAllow": ["skill_workshop"]
  },
  "skills": {
    "workshop": {
      "autonomous": {"enabled": true},
      "approvalPolicy": "auto",
      "maxPending": 200,
      "maxSkillBytes": 40000,
      "allowSymlinkTargetWrites": false
    }
  }
}
