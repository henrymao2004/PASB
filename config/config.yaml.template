# Hermes-Agent CLI config — copy to ~/.hermes/config.yaml and fill in API key.
# This config makes hermes-CLI use OpenRouter as its agent backbone provider.
# Change `model.default` to swap the backbone (deepseek-v4-pro / gpt-5.5 / claude-opus-4.7 / ...).

memory:
  provider: local                       # store memories on disk (USER.md / MEMORY.md / skills/)

model:
  # Backbone model id (must exist on OpenRouter — verify at https://openrouter.ai/models)
  default: deepseek/deepseek-v4-pro
  provider: custom                      # OpenAI-compatible client
  base_url: https://openrouter.ai/api/v1
  # API key — PASTE YOUR KEY HERE, OR use $OPENROUTER_API_KEY (see README)
  api_key: ${OPENROUTER_API_KEY}

skills:
  creation_nudge_interval: 1            # encourage skill commits after each conversation

# Trim Hermes toolset down to the persistence primitives we actually evaluate
# (memory + skill_manage). Keeps PASB results comparable across backbones.
agent:
  disabled_toolsets:
    - web
    - browser
    - terminal
    - file
    - code_execution
    - vision
    - image_gen
    - tts
    - todo
    - clarify
    - delegation
    - cronjob
    - messaging
    - computer_use
