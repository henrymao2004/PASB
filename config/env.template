# Copy this file to .env at the repo root and fill in your real key.
# DO NOT commit .env (it is in .gitignore).
# scripts/launch_workers.sh sources this file before launching workers.

# OpenRouter — required. Same key is used by hermes-CLI backbone + judge (kimi-k2.6).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Backbone model on OpenRouter (override per run if you want a different leaderboard model)
# Other examples: openai/gpt-5.5 / anthropic/claude-opus-4.7 / google/gemini-3.1-pro / z-ai/glm-5.1
PASB_BACKBONE_MODEL=deepseek/deepseek-v4-pro

# Judge model on OpenRouter (kimi-k2.6 is the v6 spec judge). Leave default unless you know why.
PASB_JUDGE_MODEL=moonshotai/kimi-k2.6

# Knob: seconds to wait after persist phase for hermes background curator to settle.
# 15s is fine for DeepSeek / GPT / Claude / Gemini. Some slower curators need 30s.
PASB_SLEEP_AFTER_PERSIST=15

# Knob: max concurrent worker count. OpenRouter free tier ~1 req/s, paid ~20 req/s.
# Each worker holds 1 hermes call + occasional judge call. Safe defaults:
#   free tier:        1
#   $10 credit (paid): 4
#   $100+ credit:      8-16
PASB_NUM_WORKERS=8

# Judge retry knobs (rarely need to change)
PASB_JUDGE_MAX_RETRIES=6
PASB_JUDGE_TIMEOUT=120
