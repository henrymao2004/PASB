# PASB env — choose ONE backend per agent, optionally a separate judge backend.

# ============================================================
# Agent backbone (pick ONE of A / B / C)
# ============================================================

# ---- A. OpenRouter (default; easiest, no GPU needed) -------------
PASB_BACKEND=openrouter
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
PASB_BACKBONE_MODEL=deepseek/deepseek-v4-pro
# Note: PASB_BACKBONE_URL / PASB_BACKBONE_API_KEY are ignored when BACKEND=openrouter

# ---- B. Local vLLM (self-hosted GPU) -----------------------------
# PASB_BACKEND=vllm_local
# PASB_BACKBONE_MODEL=qwen3.5-27b
# PASB_BACKBONE_URL=http://localhost:8000/v1
# PASB_BACKBONE_API_KEY=local-no-key
# Reminder: vllm must be launched with `--enable-auto-tool-choice --tool-call-parser <parser>`,
# otherwise commit pipeline silently fails. See docs/TROUBLESHOOTING.md §1.

# ---- C. Custom proxy (internal Azure / Bytedance / Anthropic endpoint) ----
# PASB_BACKEND=custom_proxy
# PASB_BACKBONE_MODEL=gemini-3.1-p
# PASB_BACKBONE_URL=http://localhost:8002/v1
# PASB_BACKBONE_API_KEY=your-internal-token
# CRITICAL: your proxy MUST forward `tools` and `tool_choice` — see
# examples/proxies/openai_compat_proxy.py for a reference implementation.

# ============================================================
# Judge backend (default: OpenRouter kimi-k2.6)
# Override only if you must route judge through a proxy too.
# ============================================================
PASB_JUDGE_MODEL=moonshotai/kimi-k2.6
# PASB_JUDGE_BASE_URL=https://openrouter.ai/api/v1
# PASB_JUDGE_API_KEY=                    # falls back to OPENROUTER_API_KEY if blank
PASB_JUDGE_TIMEOUT=120
PASB_JUDGE_MAX_RETRIES=6

# ============================================================
# Run parameters (rarely changed)
# ============================================================
PASB_NUM_WORKERS=8
PASB_SLEEP_AFTER_PERSIST=15
PASB_TURN_TIMEOUT=600

# OpenClaw-only — gateway port base; per-worker port = base + worker_index
PASB_OC_GATEWAY_PORT=28900
