# PASB env — proxy-only deployment (e.g. Bytedance modelhub, internal Azure
# deployment, on-prem LLM gateway). PASB talks OpenAI /v1/chat/completions to
# a local proxy; the proxy forwards to your real endpoint and MUST preserve
# `tools` + `tool_choice` (see examples/proxies/).

# ============================================================
# Agent backbone — point at your local proxy
# ============================================================
PASB_BACKBONE_MODEL=gemini-3.1-p
PASB_BACKBONE_URL=http://localhost:8002/v1
PASB_BACKBONE_API_KEY=any-string-the-proxy-doesnt-check

# ============================================================
# Judge backend — same proxy mechanism, different port + model
# (e.g. an internal kimi-k2.5 deployment).
# ============================================================
PASB_JUDGE_MODEL=kimi-k2.5
PASB_JUDGE_BASE_URL=http://localhost:8003/v1
PASB_JUDGE_API_KEY=any-string-the-proxy-doesnt-check
PASB_JUDGE_TIMEOUT=120
PASB_JUDGE_MAX_RETRIES=6

# ============================================================
# Run parameters (rarely changed)
# ============================================================
PASB_NUM_WORKERS=8
PASB_SLEEP_AFTER_PERSIST=15
PASB_TURN_TIMEOUT=600

# OpenClaw-only — gateway port base; per-worker port = base + worker_index
PASB_OC_GATEWAY_PORT=28900

# ============================================================
# Upstream endpoint — used ONLY by the proxy processes, not by PASB itself.
# Fill these in BEFORE launching the proxies described in
# examples/proxies/README.md.
# ============================================================
# UPSTREAM_BASE_URL=https://aidp.your-company.net/api/modelhub/online/v2/crawl
# UPSTREAM_API_KEY=your-internal-token
# UPSTREAM_API_VERSION=2024-03-01-preview   # Azure-style only
