# Hermes-Agent config — Backend C: Custom proxy (internal Azure / Bytedance / closed endpoint)
# Substituted from .env via `bash scripts/setup_hermes.sh custom_proxy`.
#
# Pre-req: run a proxy (e.g. examples/proxies/openai_compat_proxy.py) that
# accepts OpenAI /v1/chat/completions and FORWARDS `tools` + `tool_choice`
# to the upstream provider. PASB ENTIRELY DEPENDS ON THIS — see
# docs/TROUBLESHOOTING.md §1 for the failure mode otherwise.

memory:
  provider: local

model:
  default: ${PASB_BACKBONE_MODEL}
  provider: custom
  base_url: ${PASB_BACKBONE_URL}
  api_key: ${PASB_BACKBONE_API_KEY}

skills:
  creation_nudge_interval: 1

agent:
  disabled_toolsets:
    - web
    - browser
    - terminal
    - file
    - code_execution
    - vision
    - image_gen
    - tts
    - todo
    - clarify
    - delegation
    - cronjob
    - messaging
    - computer_use
