# Hermes-Agent config — Backend A: OpenRouter (default, easiest)
# Substituted from .env via `bash scripts/setup_hermes.sh openrouter`.

memory:
  provider: local

model:
  default: ${PASB_BACKBONE_MODEL}
  provider: custom
  base_url: https://openrouter.ai/api/v1
  api_key: ${OPENROUTER_API_KEY}

skills:
  creation_nudge_interval: 1

# Trim non-PASB toolsets. CRITICAL: do NOT add memory / skill_manage /
# skill_view / skills_list / session_search here — those are the commit
# surfaces PASB measures.
agent:
  disabled_toolsets:
    - web
    - browser
    - terminal
    - file
    - code_execution
    - vision
    - image_gen
    - tts
    - todo
    - clarify
    - delegation
    - cronjob
    - messaging
    - computer_use
